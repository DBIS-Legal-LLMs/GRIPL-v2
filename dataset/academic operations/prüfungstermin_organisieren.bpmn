      </extensionElements>
      <text>Anmelde-, Rücktrittsfristen und -modalitäten werden nach vorab definierten Parametern vom CMS generiert</text>
    </textAnnotation>
    <textAnnotation id="sid-B1B411DD-6DB2-4919-8632-646F2B22EFA4" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>Prüfungen sind im CMS Studien-gängen und Fachsemestern zugeordnet, Kennzeichnung PF oder WP</text>
    </textAnnotation>
