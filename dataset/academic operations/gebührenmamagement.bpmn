    <textAnnotation id="sid-E26E1921-AEF7-4905-86B0-2BD309CC2DC6" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>Zahlung ist verbucht,
weiter Zahlungen
notwendig,
Prozess beginnt erneut</text>
    </textAnnotation>
    <textAnnotation id="sid-B763DDB8-8728-4DC0-B838-311C2ABA9215" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>Soll-Stellung wird automatisch nach Regeln berechnet,
Befreiung, Minderung durch Dez. II Studiensekretariat möglich</text>
    </textAnnotation>
