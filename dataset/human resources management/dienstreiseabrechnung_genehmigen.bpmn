    <textAnnotation id="xtr2-ed2f4ad43858602ad6e00efd76b0f56e" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioMetaData metaKey="bgcolor" metaValue="#FFFFFF" />
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>Eine Dienstreiseabrechnung liegt vor.</text>
    </textAnnotation>
    <textAnnotation id="xtrd-ed2f4ad43858602ad6e00efd76b0f56e" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioMetaData metaKey="bgcolor" metaValue="#FFFFFF" />
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>Die Dienstreiseabrechnung wurde nicht genehmigt.</text>
    </textAnnotation>
    <textAnnotation id="xtyf-ed2f4ad43858602ad6e00efd76b0f56e" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioMetaData metaKey="bgcolor" metaValue="#FFFFFF" />
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>Die Dienstreiseabrechnung muss überarbeitet werden.</text>
    </textAnnotation>
    <textAnnotation id="xtyr-ed2f4ad43858602ad6e00efd76b0f56e" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioMetaData metaKey="bgcolor" metaValue="#FFFFFF" />
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>Die Dienstreiseabrechnung wurde genehmigt.</text>
    </textAnnotation>
    <textAnnotation id="sid-1688g-ed2f4ad43858602ad6e00efd76b0f56e" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioMetaData metaKey="bgcolor" metaValue="#FFFFFF" />
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>Beförderungsmittel, Kontierung, Finanzierung, Angaben zur Kostenerstattung</text>
    </textAnnotation>
    <textAnnotation id="sid-16f63-ed2f4ad43858602ad6e00efd76b0f56e" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioMetaData metaKey="bgcolor" metaValue="#FFFFFF" />
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>Dokumente können hochgeladen werden. Notizen können ergänzt werden.</text>
    </textAnnotation>
    <textAnnotation id="sid-12y8s-ed2f4ad43858602ad6e00efd76b0f56e" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioType dataObjectType="IT-System" />
        <signavio:signavioMetaData metaKey="bgcolor" metaValue="#9CC7FF" />
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>Alle Vorgänge anzeigen</text>
    </textAnnotation>
  </process>
