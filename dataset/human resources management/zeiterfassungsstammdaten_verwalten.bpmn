    <textAnnotation id="a9lb-1f26bc8df5723441a7c06602674717dc" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioMetaData metaKey="bgcolor" metaValue="#FFFFFF" />
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>ältere Daten bis zu einem bestimmten Monat</text>
    </textAnnotation>
    <textAnnotation id="cb0m-1f26bc8df5723441a7c06602674717dc" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioMetaData metaKey="bgcolor" metaValue="#FFFFFF" />
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>i. d. R. Monatssätze, können z. B. einmal im Jahr angelegt werden</text>
    </textAnnotation>
    <textAnnotation id="drfi-1f26bc8df5723441a7c06602674717dc" signavio:alignment="left">
