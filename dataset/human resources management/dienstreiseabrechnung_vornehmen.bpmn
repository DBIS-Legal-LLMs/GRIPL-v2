    <textAnnotation id="sid-17bby-ed2f4ad43858602ad6e00efd76b0f56e" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioMetaData metaKey="bgcolor" metaValue="#FFFFFF" />
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>Suche erfolgt anhand der Referenz (hier Referenz Q=QIS-Abrechnung).</text>
    </textAnnotation>
    <textAnnotation id="sid-17tts-ed2f4ad43858602ad6e00efd76b0f56e" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioMetaData metaKey="bgcolor" metaValue="#FFFFFF" />
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>Die Referenz wird von Q auf E (abgerechnete Reisen) geändert.</text>
    </textAnnotation>
    <textAnnotation id="sid-1gozr-ed2f4ad43858602ad6e00efd76b0f56e" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioMetaData metaKey="bgcolor" metaValue="#FFFFFF" />
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>alle Regeisterkarten aus Dienstreiseabbrechnung genehmigen</text>
    </textAnnotation>
    <textAnnotation id="sid-1prmy-ed2f4ad43858602ad6e00efd76b0f56e" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioMetaData metaKey="bgcolor" metaValue="#FFFFFF" />
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>Bestehend aus: Daten in die HÜL-Tabelle schreiben, Buchungsart vergeben, HÜL-Nummer vergeben, Daten aus der HÜL-Tabelle auslesen</text>
    </textAnnotation>
    <textAnnotation id="sid-282xo-ed2f4ad43858602ad6e00efd76b0f56e" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioMetaData metaKey="bgcolor" metaValue="#FFFFFF" />
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>Eine Dienstreiseabrechnung liegt genehmigt vor. </text>
    </textAnnotation>
    <textAnnotation id="sid-28br1-ed2f4ad43858602ad6e00efd76b0f56e" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioMetaData metaKey="bgcolor" metaValue="#FFFFFF" />
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>Eine Dienstreise wurde abgerechnet.</text>
    </textAnnotation>
    <textAnnotation id="sid-1dysb-ed2f4ad43858602ad6e00efd76b0f56e" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioType dataObjectType="IT-System" />
        <signavio:signavioMetaData metaKey="bgcolor" metaValue="#9CC7FF" />
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>Bank_Registerkarte</text>
    </textAnnotation>
    <textAnnotation id="sid-200gs-ed2f4ad43858602ad6e00efd76b0f56e" signavio:alignment="left">
      <extensionElements>
        <signavio:signavioType dataObjectType="IT-System" />
        <signavio:signavioMetaData metaKey="bgcolor" metaValue="#9CC7FF" />
        <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000" />
      </extensionElements>
      <text>Übernachtung_Registerkarte</text>
    </textAnnotation>
  </process>
