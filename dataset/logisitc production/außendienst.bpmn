      <textAnnotation id="sid-0D352C08-9425-4134-B079-853627DE0D9A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>erste Recherche zu passenden Angeboten</text>
