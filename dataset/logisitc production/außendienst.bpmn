      <textAnnotation id="sid-88FE99FF-8A4C-461A-8B7E-C4BFD7CF0937" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Angebotserstellung und Auftragserfassung durch ACM</text>
