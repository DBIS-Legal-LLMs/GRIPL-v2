      <textAnnotation id="sid-E3FE8AB5-E346-438D-B66A-639D8F4C60AC" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Einkäufer entscheidet bei welchem Lieferanten Produkt gekauft wird</text>
      </textAnnotation>
      <textAnnotation id="sid-626339CE-5B58-4216-A790-5161759155CB" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>über Gesamtlage und besprochene Produkte </text>
      </textAnnotation>
      <textAnnotation id="sid-44404CFA-5B04-4C33-B352-4D242599DD44" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Vereinbarungen mit Kunde im Reisebericht ersichtlich</text>
      </textAnnotation>
      <textAnnotation id="sid-627A20ED-59F3-457B-B575-94158EFEEB6C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>ATE Services:
- Expert Walk
- Expert Education
- Expert Teardown
- Expert Design
- Expert Test Services
- Expert Assortment Analysis</text>
      </textAnnotation>
