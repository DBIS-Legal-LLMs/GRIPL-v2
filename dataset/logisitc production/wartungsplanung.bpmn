      <textAnnotation id="sid-A1E257CB-5AE1-4793-A29C-DACFA526791A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Übermittlung beenden?</text>
      </textAnnotation>
      <textAnnotation id="sid-390A3226-0EC3-4297-A367-61ED773AA1CA" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Wartungspläne vorhanden?</text>
      </textAnnotation>
      <textAnnotation id="sid-ED8BF9E2-9AC9-4F09-8696-C5E6B366E667" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Maschinenfehlverhalten erkannt</text>
      </textAnnotation>
      <textAnnotation id="sid-F87E68DB-3705-4F27-967E-771D0BBD4307" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Fehlverhalten kritisch?</text>
      </textAnnotation>
      <textAnnotation id="sid-EC72C030-39CC-44FD-9971-4F2CAA239695" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Während Wartung zusätzlicher Wartungsbedarf erkannt</text>
      </textAnnotation>
      <textAnnotation id="sid-BDBB6DDC-0B9F-47C3-AC81-6F4C2DB3646B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Maschine in Betrieb?</text>
      </textAnnotation>
      <textAnnotation id="sid-E30963A8-A474-43E6-B754-1407CED339AF" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Ein Wartungssystem kann entweder ein Informationssystem sein, oder Dateien, oder manuell gepflegt werden</text>
      </textAnnotation>
      <textAnnotation id="sid-F15C1A77-F500-4D3B-9578-6055365F462B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Betriebsstunden erreicht</text>
      </textAnnotation>
   </process>
